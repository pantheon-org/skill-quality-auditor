{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scoring Patterns Config",
  "description": "Schema for the externalised D1/D6/analysis pattern lists consumed by internal/patternconfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "patterns"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["d1_knowledge_delta", "analysis_quality", "d6_freedom_calibration"],
      "properties": {
        "d1_knowledge_delta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["beginner_signals", "expert_signals"],
          "properties": {
            "beginner_signals": { "$ref": "#/$defs/nonEmptyStringArray" },
            "expert_signals": { "$ref": "#/$defs/nonEmptyStringArray" }
          }
        },
        "analysis_quality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hedge_words", "vague_words", "passive_patterns"],
          "properties": {
            "hedge_words": { "$ref": "#/$defs/nonEmptyStringArray" },
            "vague_words": { "$ref": "#/$defs/nonEmptyStringArray" },
            "passive_patterns": { "$ref": "#/$defs/nonEmptyStringArray" }
          }
        },
        "d6_freedom_calibration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["when_not_to_use"],
          "properties": {
            "when_not_to_use": { "$ref": "#/$defs/nonEmptyStringArray" }
          }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
