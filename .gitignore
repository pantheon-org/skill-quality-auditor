dist/
site/
.tmp/
coverage.out
coverage.html
.aislop/
.claude/skills
.codex/
.cursor/
.github/skills
.tessl/
.env

# Override the global ~/.gitignore `tessl.json` exclusion so the project
# manifest is tracked for CI and local eval.
!tessl.json

# Override the global ~/.gitignore `.agents/` and `.context/` exclusions so
# project-managed files under these directories are tracked.
# Must un-ignore parent dirs first — git won't descend into an excluded directory.
!.agents/
!.agents/skills/
.agents/skills/tessl__*
!.agents/skills/adr-capture/
!.agents/skills/context-file/
!.agents/skills/context-index/
!.context/
!.context/**/
!opencode.json

# The broad !.context/**/ un-ignore above overrides the top-level .aislop/
# rule for anything nested under .context/ — re-exclude it explicitly.
.context/**/.aislop/