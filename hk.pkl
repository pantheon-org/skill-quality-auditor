amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

local preCommit = new Mapping<String, Step> {
    ["go-fmt"] {
        // Mirror lefthook's "**/*.go" — `*.go` would not match nested files and
        // would silently skip scorer/, cmd/, reporter/, etc.
        glob = List("**/*.go")
        // fail if any staged Go file is not gofmt-clean
        check = "test -z \"$(gofmt -l {{files}})\""
    }
    ["go-vet"] {
        glob = List("**/*.go")
        check = "go vet ./..."
    }
    ["golangci-lint"] {
        glob = List("**/*.go")
        check = "golangci-lint run ./..."
    }
    ["markdownlint"] {
        glob = List("**/*.md")
        exclude = List("cmd/assets/**", "testdata/**", ".github/**", "CHANGELOG.md")
        check = "markdownlint-cli2 {{files}}"
        fix = "markdownlint-cli2 --fix {{files}}"
    }
    ["shellcheck"] {
        glob = List("scripts/**/*.sh")
        check = "shellcheck {{files}}"
    }
    ["context-frontmatter"] {
        // Exclude plugins/ — plugin .md files use Tessl frontmatter (name, description) not context schema.
        glob = List(".context/**/*.md")
        exclude = List(".context/plugins/**")
        check = ".context/plugins/pantheon-org/context-mgmt/context-index/scripts/validate-context-frontmatter.sh {{files}}"
    }
    ["context-index"] {
        glob = List(".context/**/*.md")
        exclude = List(".context/plugins/**")
        fix = ".context/plugins/pantheon-org/context-mgmt/context-index/scripts/regenerate-context-index.sh"
        check = ".context/plugins/pantheon-org/context-mgmt/context-index/scripts/regenerate-context-index.sh --check"
    }
    ["adr-frontmatter"] {
        glob = List("docs/ADR/adr-*.md")
        check = ".context/plugins/pantheon-org/context-mgmt/context-index/scripts/check-context-frontmatter.sh {{files}}"
    }
    ["adr-index"] {
        glob = List("docs/ADR/adr-*.md")
        fix = ".context/plugins/pantheon-org/governance/adr-capture/scripts/regenerate-adr-index.sh"
        check = ".context/plugins/pantheon-org/governance/adr-capture/scripts/regenerate-adr-index.sh --check"
    }
    ["adr-undocumented"] {
        glob = List(".context/**/*.md")
        check = ".context/plugins/pantheon-org/governance/adr-capture/scripts/check-undocumented-decisions.sh"
    }
}

local prePush = new Mapping<String, Step> {
    ["go-test"] {
        glob = List("**/*.go")
        check = "go test ./..."
    }
    ["plan-drift"] {
        check = "scripts/check-plan-drift.sh"
    }
    ["docs-drift"] {
        check = "scripts/check-docs-drift.sh"
    }
    // Build always runs (no glob) so the skill-* steps below have a fresh binary,
    // even on a push that touches only cmd/assets/** and no .go files.
    ["go-build"] {
        check = "go build -o dist/skill-auditor ."
    }
    ["skill-validate"] {
        glob = List("cmd/assets/**")
        depends = List("go-build")
        check = "./dist/skill-auditor validate artifacts"
    }
    ["skill-duplication"] {
        glob = List("cmd/assets/**")
        depends = List("go-build")
        check = "./dist/skill-auditor duplication cmd/assets"
    }
    ["skill-batch"] {
        glob = List("cmd/assets/**")
        depends = List("go-build")
        check = "./dist/skill-auditor batch ./cmd/assets --fail-below B"
    }
    // Structural eval gate — required every push (ADR-007 Tier 1).
    // No LLM key needed; validates scenario dirs + criteria sum-to-100.
    ["skill-eval-structural"] {
        glob = List("cmd/assets/**")
        depends = List("go-build")
        check = "./dist/skill-auditor eval ./cmd/assets --fail-below 0"
    }
}

hooks {
    ["pre-commit"] {
        fix = true       // run fix steps (markdownlint --fix) and restage
        stash = "git"    // stash unstaged changes while fixing
        steps = preCommit
    }
    ["pre-push"] {
        steps = prePush
    }
    // enable `hk check` / `hk fix` for manual + CI use
    ["check"] {
        steps = preCommit
    }
    ["fix"] {
        fix = true
        steps = preCommit
    }
}
