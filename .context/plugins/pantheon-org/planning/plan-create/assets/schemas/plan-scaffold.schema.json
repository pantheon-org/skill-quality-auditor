{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan-scaffold",
  "title": "Plan scaffold",
  "description": "Describes the structure of a .context/plans/ file generated by the plan-create skill.",
  "type": "object",
  "required": ["plan"],
  "additionalProperties": false,
  "properties": {
    "plan": {
      "type": "object",
      "required": ["filename", "frontmatter", "goal", "phases", "open_questions"],
      "additionalProperties": false,
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "frontmatter": {
          "type": "object",
          "required": ["title", "type", "status", "date", "effort", "value"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "enum": ["PLAN"] },
            "status": { "type": "string", "enum": ["DRAFT"] },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "effort": {
              "type": "string",
              "enum": ["S", "M", "L", "TBD"],
              "description": "T-shirt-sized total effort estimate, matching the skill-auditor remediation-plan convention. TBD only if genuinely blocked on an unresolved Open Question."
            },
            "value": {
              "type": "string",
              "enum": ["HIGH", "MEDIUM", "LOW"],
              "description": "Benefit-of-action grade (UPPER_CASE), distinct from effort (cost) and severity (risk-of-inaction). Graded against .context/instructions/value-rubric.md. Required for a new plan (DRAFT status). The 'what's next' read protocol sorts by value descending, then effort ascending."
            },
            "related": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "goal": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "object",
          "properties": {
            "in_scope": { "type": "array", "items": { "type": "string" } },
            "out_of_scope": { "type": "array", "items": { "type": "string" } }
          }
        },
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "tasks"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "exit_criterion": { "type": "string" },
              "tasks": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["description"],
                  "properties": {
                    "description": { "type": "string" },
                    "wave": { "type": "string" },
                    "can_parallelise_with": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    }
  }
}
